#!/usr/bin/env bash
# flex-fe-dev-open <remote> <branch>
#
# 주어진 remote 의 submodule 을 찾고, 그 안에서 <branch> 가 체크아웃된
# worktree 를 VS Code (code) 로 연다. dev 서버는 띄우지 않는다.

set -euo pipefail

# shellcheck source=lib.sh
source "$(dirname "$(readlink -f "$0")")/lib.sh"

usage() {
  cat <<EOF
Usage: flex-fe-dev-open <app> <branch>

  <app>     remote 앱 이름 (예: brain, ai, custom-page) 또는 host
            'remotes-' / '@flex-apps/remotes-' 접두사 붙여도 OK
            host 는 @flex-apps/host (web-applications/host) 로 해석
  <branch>  체크아웃된 worktree 의 브랜치 이름

Env:
  FLEX_ROOT          (default: \$HOME/Projects/flex)
  FLEX_PARENT_REPO   submodule 들이 묶여있는 부모 레포
                     (default: \$FLEX_ROOT/flex-frontend-repositories)
EOF
}

if [[ "${1:-}" == "-h" || "${1:-}" == "--help" ]]; then
  usage
  exit 0
fi

if [[ $# -ne 2 ]]; then
  usage
  exit 2
fi

remote=$(normalize_remote "$1")
branch="$2"
resolve_app_layout

# 앱 → submodule → worktree 해석 (없으면 자동 생성)
target=$(resolve_worktree)

echo "→ app: $remote ($workspace)"
echo "→ branch: $branch"
echo "→ open: $target"
exec code "$target"
