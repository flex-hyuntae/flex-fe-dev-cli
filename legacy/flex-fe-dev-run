#!/usr/bin/env bash
# flex-fe-dev-run [--no-open] <remote> <branch>
#
# 주어진 remote 의 submodule 을 찾고, 그 안에서 <branch> 가 체크아웃된
# worktree 로 진입해서 VS Code 로 열고(code) yarn → .env.local → yarn turbo run dev 를 수행한다.

set -euo pipefail

# shellcheck source=lib.sh
source "$(dirname "$(readlink -f "$0")")/lib.sh"

usage() {
  cat <<EOF
Usage: flex-fe-dev-run [--no-open] <app> <branch>

  <app>     remote 앱 이름 (예: brain, ai, custom-page) 또는 host
            'remotes-' / '@flex-apps/remotes-' 접두사 붙여도 OK
            host 는 @flex-apps/host (web-applications/host) 로 해석
  <branch>  체크아웃된 worktree 의 브랜치 이름

Options:
  --no-open  worktree 를 VS Code (code) 로 열지 않는다

Env:
  FLEX_ROOT          (default: \$HOME/Projects/flex)
  FLEX_PARENT_REPO   submodule 들이 묶여있는 부모 레포
                     (default: \$FLEX_ROOT/flex-frontend-repositories)
EOF
}

if [[ "${1:-}" == "-h" || "${1:-}" == "--help" ]]; then
  usage
  exit 0
fi

open_editor=1
if [[ "${1:-}" == "--no-open" ]]; then
  open_editor=0
  shift
fi

if [[ $# -ne 2 ]]; then
  usage
  exit 2
fi

remote=$(normalize_remote "$1")
branch="$2"
resolve_app_layout

# 1~2. 앱 → submodule → worktree 해석 (없으면 자동 생성)
target=$(resolve_worktree)

echo "→ app: $remote ($workspace)"
echo "→ branch: $branch"
echo "→ cwd: $target"
cd "$target"

# 3. VS Code 로 열기 (비동기 — dev 서버와 병행)
if [[ "$open_editor" -eq 1 ]]; then
  echo "→ code $target"
  code "$target"
fi

# 4. yarn install
echo ""
echo "→ yarn install"
yarn

# 5. .env.local 보장
app_dir="web-applications/$app_subdir"
env_local="$app_dir/.env.local"
env_example="$app_dir/.env.example"
echo ""
if [[ -f "$env_local" ]]; then
  echo "✓ $env_local 이미 존재 — 유지"
elif [[ -f "$env_example" ]]; then
  cp "$env_example" "$env_local"
  echo "✓ $env_example → $env_local 복사"
else
  echo "⚠ $env_example 도 $env_local 도 없음 — env 설정 없이 진행"
fi

# 6. dev 서버 (foreground, exec 으로 PID 승계)
echo ""
echo "→ yarn turbo run dev --filter=$workspace"
echo ""
exec yarn turbo run dev --filter="$workspace"
